<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<script src="./support.js"></script>
</head>
<body>
<x-dc>
<helmet>
<style>
@font-face{font-family:'UD Digi Kyokasho';src:url('assets/fonts/UDDigiKyokasho-R.ttc') format('truetype');font-weight:400;font-display:swap;}
@font-face{font-family:'UD Digi Kyokasho';src:url('assets/fonts/UDDigiKyokasho-B.ttc') format('truetype');font-weight:700;font-display:swap;}
@font-face{font-family:'Meiryo';src:url('assets/fonts/Meiryo-R.ttc') format('truetype');font-weight:400;font-display:swap;}
@font-face{font-family:'Meiryo';src:url('assets/fonts/Meiryo-B.ttc') format('truetype');font-weight:700;font-display:swap;}
html{scroll-behavior:smooth;}
body{margin:0;}
.portal-root{
 --font-display:'UD Digi Kyokasho','Hiragino Maru Gothic ProN','Yu Gothic',sans-serif;
 --font-body:'Meiryo','Hiragino Kaku Gothic ProN','Yu Gothic',sans-serif;
 --font-mono:ui-monospace,'SFMono-Regular','Consolas',monospace;
 --bg:#fbfcf5; --surface:#ffffff; --surface-2:#f3f5ea; --sunken:#eff2e7;
 --text-strong:#2a2e22; --text-body:#4a4f3f; --text-muted:#6e7363; --text-faint:#9aa08c;
 --border:#e2e6d6; --border-strong:#c4c9b8;
 --brand:#189048; --brand-strong:#13783b; --brand-soft:#e8f6ee;
 --warn-soft:#fff3cc; --warn-text:#8a6800; --warn-border:#ffe08a;
 --danger-soft:#fbe0e0; --danger-text:#c62c2c; --danger-border:#ef6a6a;
 --gold:#f7b500;
 --nav-bg:rgba(251,252,245,.82);
 --shadow-sm:0 2px 6px rgba(42,46,34,.08);
 --shadow-md:0 6px 16px rgba(42,46,34,.10);
 --shadow-lg:0 16px 36px rgba(42,46,34,.16);
}
.portal-root[data-theme="dark"]{
 --bg:#171a10; --surface:#22261a; --surface-2:#2b3020; --sunken:#1d2114;
 --text-strong:#f3f6ea; --text-body:#dde2d2; --text-muted:#9aa08c; --text-faint:#727866;
 --border:#383d2b; --border-strong:#4a4f3f;
 --brand:#5fbe85; --brand-strong:#94d5ae; --brand-soft:rgba(47,164,96,.16);
 --warn-soft:rgba(255,210,63,.14); --warn-text:#ffe08a; --warn-border:rgba(255,210,63,.4);
 --danger-soft:rgba(239,106,106,.16); --danger-text:#f4a18d; --danger-border:rgba(239,106,106,.45);
 --gold:#ffd23f;
 --nav-bg:rgba(23,26,16,.82);
 --shadow-sm:0 2px 6px rgba(0,0,0,.35);
 --shadow-md:0 6px 16px rgba(0,0,0,.45);
 --shadow-lg:0 16px 36px rgba(0,0,0,.55);
}
@keyframes floaty{0%,100%{transform:translateY(0) rotate(-4deg);}50%{transform:translateY(-10px) rotate(-4deg);}}
.evt-track{scrollbar-width:none;-ms-overflow-style:none;}
.evt-track::-webkit-scrollbar{display:none;}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
</helmet>

<template id="__bundler_thumbnail"><svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"><rect width="100" height="100" rx="20" fill="#189048"/><circle cx="38" cy="34" r="13" fill="#c0d830"/><path d="M30 62h40M30 72h28" stroke="#fff" stroke-width="5" stroke-linecap="round"/></svg></template>

<div class="portal-root" data-theme="{{ theme }}" style="min-height:100vh;background-color:var(--bg);color:var(--text-body);font-family:var(--font-body);font-size:15px;line-height:1.7;transition:background-color .35s ease,color .35s ease;">

  <header style="position:sticky;top:0;z-index:50;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);background:var(--nav-bg);border-bottom:1px solid var(--border);">
    <div style="max-width:1200px;margin:0 auto;padding:11px 24px;display:flex;flex-direction:column;gap:11px;">
      <div style="display:flex;align-items:center;gap:14px;">
        <a href="#top" style="display:flex;align-items:center;gap:10px;text-decoration:none;flex:none;">
          <img src="data:image/png;base64," alt="ふたば" width="34" height="36" style="display:block;" />
          <span style="display:flex;flex-direction:column;line-height:1.1;">
            <span style="font-family:var(--font-display);font-weight:700;font-size:16px;color:var(--text-strong);letter-spacing:-.01em;">探究リサーチポータル</span>
            <span style="font-size:10px;color:var(--text-faint);letter-spacing:.14em;font-family:var(--font-mono);">GENERAL INQUIRY</span>
          </span>
        </a>
        <div style="flex:1;"></div>
        <div style="position:relative;flex:none;width:230px;max-width:42vw;">
          <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-faint);font-size:14px;pointer-events:none;">⌕</span>
          <input type="search" value="{{ query }}" onInput="{{ setQuery }}" placeholder="サイトを検索…" style="width:100%;box-sizing:border-box;padding:9px 12px 9px 32px;border-radius:999px;border:1px solid var(--border);background:var(--surface);color:var(--text-strong);font-family:var(--font-body);font-size:13.5px;outline:none;" />
        </div>
        <button onClick="{{ toggleFavView }}" title="お気に入りだけ表示" style="{{ favBtnStyle }}">
          <span style="font-size:14px;line-height:1;">★</span><span>{{ favCount }}</span>
        </button>
        <button onClick="{{ toggleTheme }}" title="表示モード切替" style="flex:none;width:38px;height:38px;display:inline-flex;align-items:center;justify-content:center;border-radius:999px;border:1px solid var(--border);background:var(--surface);color:var(--text-body);cursor:pointer;transition:all .2s;">
          <sc-if value="{{ themeIsDark }}" hint-placeholder-val="{{ true }}">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.2"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
          </sc-if>
          <sc-if value="{{ themeIsLight }}">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"></path></svg>
          </sc-if>
        </button>
      </div>
      <div style="display:flex;gap:7px;overflow-x:auto;padding-bottom:2px;scrollbar-width:thin;">
        <sc-for list="{{ chips }}" as="chip" hint-placeholder-count="8">
          <button onClick="{{ chip.onClick }}" style="{{ chip.style }}">{{ chip.label }}</button>
        </sc-for>
      </div>
    </div>
  </header>

  <section style="background:var(--surface-2);border-bottom:1px solid var(--border);">
    <div style="max-width:1200px;margin:0 auto;padding:22px 24px 26px;">
      <div style="display:flex;align-items:flex-end;gap:14px;flex-wrap:wrap;margin-bottom:16px;">
        <div style="flex:1;min-width:200px;">
          <div style="display:flex;align-items:center;gap:9px;">
            <span style="font-family:var(--font-mono);font-size:10.5px;letter-spacing:.18em;color:var(--brand);">SEMINARS &amp; EVENTS</span>
            <span style="width:5px;height:5px;border-radius:50%;background:var(--border-strong);"></span>
            <span style="font-size:11.5px;color:var(--text-faint);">{{ evtCount }}件</span>
          </div>
          <h2 style="margin:4px 0 0;font-family:var(--font-display);font-weight:700;font-size:24px;letter-spacing:-.01em;color:var(--text-strong);">セミナー・イベント情報</h2>
          <p style="margin:3px 0 0;font-size:12.5px;color:var(--text-muted);">クリックでチラシ（PDF）／ダブルクリックで申込ページが開きます。</p>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
          <div style="display:inline-flex;padding:3px;background:var(--sunken);border-radius:999px;border:1px solid var(--border);">
            <button onClick="{{ setCarouselView }}" style="{{ carBtnStyle }}">カルーセル</button>
            <button onClick="{{ setListView }}" style="{{ listBtnStyle }}">一覧表</button>
          </div>
          <sc-if value="{{ isCarousel }}" hint-placeholder-val="{{ true }}">
            <div style="display:flex;gap:6px;">
              <button onClick="{{ evtPrev }}" aria-label="前へ" style="width:38px;height:38px;flex:none;display:inline-flex;align-items:center;justify-content:center;border-radius:999px;border:1px solid var(--border);background:var(--surface);color:var(--text-body);cursor:pointer;transition:all .18s;" style-hover="border-color:var(--brand);color:var(--brand);">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"></path></svg>
              </button>
              <button onClick="{{ evtNext }}" aria-label="次へ" style="width:38px;height:38px;flex:none;display:inline-flex;align-items:center;justify-content:center;border-radius:999px;border:1px solid var(--border);background:var(--surface);color:var(--text-body);cursor:pointer;transition:all .18s;" style-hover="border-color:var(--brand);color:var(--brand);">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"></path></svg>
              </button>
            </div>
          </sc-if>
        </div>
      </div>

      <sc-if value="{{ isCarousel }}" hint-placeholder-val="{{ true }}">
        <div>
          <div ref="{{ trackRef }}" class="evt-track" onMouseEnter="{{ evtPause }}" onMouseLeave="{{ evtResume }}" style="display:flex;gap:16px;overflow-x:auto;scroll-snap-type:x mandatory;padding:4px 2px 8px;">
            <sc-for list="{{ events }}" as="ev" hint-placeholder-count="4">
              <div onClick="{{ ev.onClick }}" onDoubleClick="{{ ev.onDblClick }}" title="クリック：チラシを開く ／ ダブルクリック：申込ページ" style="scroll-snap-align:start;flex:none;width:255px;cursor:pointer;background:var(--surface);border:1px solid var(--border);border-radius:18px;overflow:hidden;box-shadow:var(--shadow-sm);transition:transform .22s cubic-bezier(.34,1.56,.64,1),box-shadow .22s ease,border-color .22s ease;" style-hover="transform:translateY(-4px);box-shadow:var(--shadow-lg);border-color:{{ ev.accent }};">
                <div style="position:relative;height:152px;background:{{ ev.posterBg }};overflow:hidden;">
                  <div style="position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;gap:8px;padding:18px;color:#fff;">
                    <span style="font-family:var(--font-mono);font-size:9.5px;letter-spacing:.16em;opacity:.85;">FLYER · PDF</span>
                    <span style="font-family:var(--font-display);font-weight:700;font-size:15.5px;line-height:1.45;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">{{ ev.title }}</span>
                  </div>
                  {{ ev.thumbImg }}
                  <span style="position:absolute;top:10px;right:10px;{{ ev.formatBadge }}">{{ ev.formatLabel }}</span>
                  <sc-if value="{{ ev.isSoon }}" hint-placeholder-val="{{ false }}">
                    <span style="position:absolute;top:10px;left:10px;display:inline-flex;align-items:center;gap:4px;padding:4px 9px;border-radius:999px;background:var(--danger-text);color:#fff;font-family:var(--font-display);font-weight:700;font-size:10.5px;box-shadow:0 2px 6px rgba(0,0,0,.25);">{{ ev.soonLabel }}</span>
                  </sc-if>
                </div>
                <div style="padding:13px 15px 15px;">
                  <p style="margin:0;font-family:var(--font-display);font-weight:700;font-size:14.5px;line-height:1.5;color:var(--text-strong);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;min-height:43px;">{{ ev.title }}</p>
                  <div style="margin-top:10px;display:flex;flex-direction:column;gap:6px;">
                    <div style="display:flex;align-items:center;gap:7px;font-size:12px;color:var(--text-body);">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="{{ ev.accent }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none;"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
                      <span style="font-family:var(--font-display);font-weight:700;">{{ ev.dateLabel }}</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:7px;font-size:11.5px;color:var(--text-muted);">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none;"><path d="M12 6v6l4 2"></path><circle cx="12" cy="12" r="9"></circle></svg>
                      <span>締切 {{ ev.deadlineLabel }}</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:7px;font-size:11.5px;color:var(--text-muted);">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none;"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M15 9h.01M9 13h.01M15 13h.01"></path></svg>
                      <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ ev.organizer }}</span>
                    </div>
                  </div>
                  <div style="margin-top:12px;padding-top:11px;border-top:1px dashed var(--border);display:flex;align-items:center;justify-content:space-between;gap:8px;">
                    <span style="font-size:10.5px;color:var(--text-faint);font-family:var(--font-display);font-weight:700;">{{ ev.target }}</span>
                    <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-family:var(--font-display);font-weight:700;color:{{ ev.accent }};">申込 <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"></path></svg></span>
                  </div>
                </div>
              </div>
            </sc-for>
          </div>
          <div style="display:flex;justify-content:center;gap:7px;margin-top:12px;">
            <sc-for list="{{ evtDots }}" as="dot" hint-placeholder-count="5">
              <button onClick="{{ dot.onClick }}" aria-label="スライド" style="{{ dot.style }}"></button>
            </sc-for>
          </div>
        </div>
      </sc-if>

      <sc-if value="{{ isList }}" hint-placeholder-val="{{ false }}">
        <div style="overflow-x:auto;border:1px solid var(--border);border-radius:16px;background:var(--surface);box-shadow:var(--shadow-sm);">
          <table style="width:100%;border-collapse:collapse;min-width:760px;font-size:13px;">
            <thead>
              <tr style="background:var(--sunken);">
                <th style="text-align:left;padding:12px 16px;font-family:var(--font-display);font-weight:700;font-size:11.5px;color:var(--text-muted);letter-spacing:.04em;white-space:nowrap;">イベント</th>
                <th style="text-align:left;padding:12px 12px;font-family:var(--font-display);font-weight:700;font-size:11.5px;color:var(--text-muted);white-space:nowrap;">開催日</th>
                <th style="text-align:left;padding:12px 12px;font-family:var(--font-display);font-weight:700;font-size:11.5px;color:var(--text-muted);white-space:nowrap;">申込締切</th>
                <th style="text-align:left;padding:12px 12px;font-family:var(--font-display);font-weight:700;font-size:11.5px;color:var(--text-muted);white-space:nowrap;">形式</th>
                <th style="text-align:left;padding:12px 12px;font-family:var(--font-display);font-weight:700;font-size:11.5px;color:var(--text-muted);white-space:nowrap;">対象</th>
                <th style="text-align:right;padding:12px 16px;font-family:var(--font-display);font-weight:700;font-size:11.5px;color:var(--text-muted);white-space:nowrap;">リンク</th>
              </tr>
            </thead>
            <tbody>
              <sc-for list="{{ events }}" as="ev" hint-placeholder-count="5">
                <tr style="border-top:1px solid var(--border);">
                  <td style="padding:13px 16px;max-width:320px;">
                    <span style="font-family:var(--font-display);font-weight:700;font-size:13.5px;color:var(--text-strong);line-height:1.5;">{{ ev.title }}</span>
                    <span style="display:block;margin-top:3px;font-size:11.5px;color:var(--text-muted);">{{ ev.organizer }}</span>
                  </td>
                  <td style="padding:13px 12px;white-space:nowrap;font-family:var(--font-display);font-weight:700;color:var(--text-body);">{{ ev.dateLabel }}</td>
                  <td style="padding:13px 12px;white-space:nowrap;color:var(--text-body);">
                    <span style="display:inline-flex;align-items:center;gap:6px;">{{ ev.deadlineLabel }}<sc-if value="{{ ev.isSoon }}" hint-placeholder-val="{{ false }}"><span style="padding:2px 7px;border-radius:999px;background:var(--danger-soft);color:var(--danger-text);font-family:var(--font-display);font-weight:700;font-size:10px;">{{ ev.soonLabel }}</span></sc-if></span>
                  </td>
                  <td style="padding:13px 12px;white-space:nowrap;"><span style="{{ ev.formatBadge }}">{{ ev.formatLabel }}</span></td>
                  <td style="padding:13px 12px;white-space:nowrap;font-size:12px;color:var(--text-muted);">{{ ev.target }}</td>
                  <td style="padding:13px 16px;white-space:nowrap;text-align:right;">
                    <span style="display:inline-flex;gap:7px;">
                      <a href="{{ ev.pdfHref }}" target="_blank" rel="noopener noreferrer" style="display:inline-flex;align-items:center;gap:4px;padding:6px 11px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--text-body);text-decoration:none;font-family:var(--font-display);font-weight:700;font-size:11.5px;transition:all .18s;" style-hover="border-color:var(--brand);color:var(--brand);">チラシ</a>
                      <a href="{{ ev.applyUrl }}" target="_blank" rel="noopener noreferrer" style="display:inline-flex;align-items:center;gap:4px;padding:6px 11px;border-radius:8px;border:1px solid transparent;background:var(--brand);color:#fff;text-decoration:none;font-family:var(--font-display);font-weight:700;font-size:11.5px;transition:all .18s;" style-hover="background:var(--brand-strong);">申込 ↗</a>
                    </span>
                  </td>
                </tr>
              </sc-for>
            </tbody>
          </table>
        </div>
      </sc-if>
    </div>
  </section>

  <a id="top"></a>
  <section style="position:relative;overflow:hidden;background:linear-gradient(140deg,#0d4926 0%,#13783b 48%,#2fa460 100%);padding:60px 24px 68px;">
    <img src="data:image/png;base64," alt="" aria-hidden="true" style="position:absolute;right:-28px;top:18px;width:230px;opacity:.16;transform:rotate(-8deg);pointer-events:none;" />
    <div style="position:absolute;left:-80px;bottom:-90px;width:280px;height:280px;border-radius:50%;background:rgba(192,216,48,.18);pointer-events:none;"></div>
    <div style="max-width:1200px;margin:0 auto;position:relative;">
      <span style="display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:999px;background:rgba(255,255,255,.16);color:#eaf7d6;font-family:var(--font-display);font-weight:700;font-size:12.5px;letter-spacing:.04em;backdrop-filter:blur(4px);">総合的な探究の時間</span>
      <h1 style="margin:18px 0 0;font-family:var(--font-display);font-weight:700;font-size:54px;line-height:1.12;letter-spacing:-.02em;color:#ffffff;text-wrap:balance;max-width:760px;">問いを、<span style="color:#dded92;">信頼できる情報源</span>から<br/>深めよう。</h1>
      <p style="margin:16px 0 0;max-width:560px;font-size:15.5px;line-height:1.8;color:rgba(255,255,255,.86);">論文・図書・新聞・統計データ。探究学習で本当に使える情報の入口を、ひとつのポータルに集めました。</p>

      <div style="margin-top:30px;max-width:880px;background:var(--surface);border-radius:22px;padding:22px 26px;box-shadow:0 22px 55px rgba(0,0,0,.28);display:flex;gap:18px;align-items:flex-start;">
        <div style="flex:none;width:46px;height:46px;border-radius:14px;background:var(--danger-soft);color:var(--danger-text);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:26px;line-height:1;">!</div>
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:5px;">
            <span style="font-family:var(--font-mono);font-size:10.5px;letter-spacing:.16em;color:var(--danger-text);">THE GOLDEN RULE</span>
            <span style="font-family:var(--font-display);font-weight:700;font-size:12px;color:var(--text-muted);">最重要原則</span>
          </div>
          <p style="margin:0;font-family:var(--font-display);font-weight:700;font-size:19px;line-height:1.55;color:var(--text-strong);text-wrap:pretty;">Google検索の結果（まとめサイト・ブログ・Wikipedia）に、<span style="color:var(--danger-text);">安易に飛びつかない。</span></p>
          <p style="margin:8px 0 0;font-size:15px;line-height:1.7;color:var(--text-body);">書籍や論文などの<span style="font-family:var(--font-display);font-weight:700;color:var(--brand);border-bottom:2px solid var(--brand);">一次情報</span>にあたることが、探究の出発点。</p>
        </div>
      </div>
    </div>
  </section>

  <main style="max-width:1200px;margin:0 auto;padding:0 24px 8px;">

    <sc-if value="{{ filterActive }}" hint-placeholder-val="{{ false }}">
      <div style="margin-top:22px;font-size:13px;color:var(--text-muted);font-family:var(--font-display);font-weight:700;">{{ resultCount }} 件の資料を表示中</div>
    </sc-if>

    <sc-if value="{{ noResults }}" hint-placeholder-val="{{ false }}">
      <div style="margin-top:48px;text-align:center;padding:48px 24px;">
        <img src="data:image/png;base64," alt="" width="72" style="opacity:.5;" />
        <p style="margin:14px 0 0;font-family:var(--font-display);font-weight:700;font-size:18px;color:var(--text-strong);">該当する資料が見つかりませんでした</p>
        <p style="margin:6px 0 0;font-size:14px;color:var(--text-muted);">検索ワードやカテゴリ、お気に入りの絞り込みを見直してみてください。</p>
      </div>
    </sc-if>

    <sc-for list="{{ sectionsTop }}" as="section" hint-placeholder-count="3">
      <section id="{{ section.key }}" style="scroll-margin-top:160px;margin-top:50px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:4px;">
          <span style="width:11px;height:24px;border-radius:6px;background:{{ section.accent }};flex:none;"></span>
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:25px;color:var(--text-strong);margin:0;letter-spacing:-.01em;">{{ section.label }}</h2>
          <span style="font-family:var(--font-display);font-weight:700;font-size:12px;padding:3px 10px;border-radius:999px;background:{{ section.accentSoft }};color:{{ section.accent }};">{{ section.count }}</span>
        </div>
        <p style="margin:0 0 18px 23px;font-size:13.5px;color:var(--text-muted);">{{ section.desc }}</p>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(262px,1fr));gap:14px;">
          <sc-for list="{{ section.links }}" as="link" hint-placeholder-count="3">
            <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer" style="position:relative;display:flex;flex-direction:column;gap:9px;text-decoration:none;background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:17px 17px 15px;box-shadow:var(--shadow-sm);transition:transform .22s cubic-bezier(.34,1.56,.64,1),box-shadow .22s ease,border-color .22s ease;" style-hover="transform:translateY(-4px);box-shadow:var(--shadow-lg);border-color:var(--brand);">
              <div style="display:flex;align-items:flex-start;gap:10px;">
                {{ link.logo }}
                <span style="flex:1;min-width:0;font-family:var(--font-display);font-weight:700;font-size:15.5px;color:var(--text-strong);line-height:1.45;">{{ link.title }}</span>
                <span role="button" tabindex="0" onClick="{{ link.toggleFav }}" title="お気に入りに保存" style="flex:none;cursor:pointer;font-size:19px;line-height:1;color:{{ link.starColor }};">{{ link.starChar }}</span>
              </div>
              <p style="flex:1;margin:0;font-size:13px;color:var(--text-muted);line-height:1.7;">{{ link.desc }}</p>
              <div style="display:flex;align-items:center;gap:6px;font-size:11.5px;color:var(--text-faint);font-family:var(--font-mono);overflow:hidden;">
                <span style="color:var(--brand);flex:none;">↗</span><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ link.host }}</span>
              </div>
            </a>
          </sc-for>
        </div>
      </section>
    </sc-for>

    <sc-if value="{{ newsVisible }}" hint-placeholder-val="{{ true }}">
      <section id="news" style="scroll-margin-top:160px;margin-top:50px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:4px;">
          <span style="width:11px;height:24px;border-radius:6px;background:#db5e45;flex:none;"></span>
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:25px;color:var(--text-strong);margin:0;letter-spacing:-.01em;">新聞記事</h2>
        </div>
        <p style="margin:0 0 18px 23px;font-size:13.5px;color:var(--text-muted);">朝日新聞の記事データベース「朝日けんさくくん」。ログイン情報は下のカードから。</p>

        <div style="background:var(--surface);border:1px solid var(--border);border-radius:22px;box-shadow:var(--shadow-md);overflow:hidden;display:grid;grid-template-columns:1.05fr 1fr;">
          <div style="padding:26px 26px;display:flex;flex-direction:column;gap:14px;border-right:1px solid var(--border);">
            <div style="display:flex;align-items:flex-start;gap:12px;">
              <div style="flex:none;width:46px;height:46px;border-radius:14px;background:#fde8e2;color:#db5e45;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:22px;">★</div>
              <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;gap:8px;">
                  <h3 style="font-family:var(--font-display);font-weight:700;font-size:20px;color:var(--text-strong);margin:0;">朝日けんさくくん</h3>
                  <span role="button" tabindex="0" onClick="{{ asahiToggleFav }}" title="お気に入りに保存" style="cursor:pointer;font-size:19px;line-height:1;color:{{ asahiStarColor }};">{{ asahiStarChar }}</span>
                </div>
                <p style="margin:4px 0 0;font-size:13px;color:var(--text-muted);line-height:1.7;">朝日新聞の過去記事を検索できるデータベース。一次情報として新聞記事を探すのに最適。</p>
              </div>
            </div>
            <a href="https://kensaku.asahi.com/" target="_blank" rel="noopener noreferrer" style="align-self:flex-start;display:inline-flex;align-items:center;gap:8px;text-decoration:none;background:var(--brand);color:#fff;font-family:var(--font-display);font-weight:700;font-size:14px;padding:11px 20px;border-radius:999px;box-shadow:var(--shadow-sm);transition:transform .18s;" style-hover="transform:translateY(-2px);">サイトを開く <span style="font-size:13px;">↗</span></a>
            <div style="display:flex;align-items:center;gap:8px;margin-top:2px;font-size:11.5px;color:var(--text-faint);font-family:var(--font-mono);"><span style="color:var(--brand);">↗</span>kensaku.asahi.com</div>
          </div>

          <div style="padding:24px 26px;background:var(--surface-2);display:flex;flex-direction:column;gap:11px;">
            <div style="font-family:var(--font-display);font-weight:700;font-size:13px;color:var(--text-muted);letter-spacing:.02em;">ログイン情報</div>
            <div style="display:flex;align-items:center;gap:10px;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:10px 12px;">
              <span style="font-family:var(--font-display);font-weight:700;font-size:11px;color:var(--text-muted);width:30px;flex:none;">ID</span>
              <code style="flex:1;min-width:0;font-family:var(--font-mono);font-size:15px;color:var(--text-strong);letter-spacing:.02em;overflow:hidden;text-overflow:ellipsis;">dks669ken</code>
              <button onClick="{{ copyId }}" style="{{ copyIdStyle }}">{{ copyIdLabel }}</button>
            </div>
            <div style="display:flex;align-items:center;gap:10px;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:10px 12px;">
              <span style="font-family:var(--font-display);font-weight:700;font-size:11px;color:var(--text-muted);width:30px;flex:none;">PW</span>
              <code style="flex:1;min-width:0;font-family:var(--font-mono);font-size:15px;color:var(--text-strong);letter-spacing:.02em;overflow:hidden;text-overflow:ellipsis;">34a82vbsmy</code>
              <button onClick="{{ copyPw }}" style="{{ copyPwStyle }}">{{ copyPwLabel }}</button>
            </div>
            <div style="display:flex;gap:9px;align-items:flex-start;background:var(--warn-soft);border:1px solid var(--warn-border);border-radius:12px;padding:11px 13px;margin-top:3px;">
              <span style="flex:none;width:18px;height:18px;border-radius:999px;background:var(--gold);color:#3a2e00;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:12px;">!</span>
              <p style="margin:0;font-size:12.5px;line-height:1.65;color:var(--warn-text);">同時ログインは<span style="font-weight:700;">100件まで</span>。使い終わったら<span style="font-weight:700;">必ずログアウト</span>してください。</p>
            </div>
          </div>
        </div>
      </section>
    </sc-if>

    <sc-if value="{{ statsVisible }}" hint-placeholder-val="{{ true }}">
      <section id="stats" style="scroll-margin-top:160px;margin-top:50px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:4px;">
          <span style="width:11px;height:24px;border-radius:6px;background:#6f8a12;flex:none;"></span>
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:25px;color:var(--text-strong);margin:0;letter-spacing:-.01em;">統計データ</h2>
        </div>
        <p style="margin:0 0 18px 23px;font-size:13.5px;color:var(--text-muted);">政府統計の入口と、テーマ別のデータ集。分野別は表示方法を切り替えられます。</p>

        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(262px,1fr));gap:14px;">
          <sc-for list="{{ statsTop }}" as="link" hint-placeholder-count="2">
            <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer" style="position:relative;display:flex;flex-direction:column;gap:9px;text-decoration:none;background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:17px 17px 15px;box-shadow:var(--shadow-sm);transition:transform .22s cubic-bezier(.34,1.56,.64,1),box-shadow .22s ease,border-color .22s ease;" style-hover="transform:translateY(-4px);box-shadow:var(--shadow-lg);border-color:var(--brand);">
              <div style="display:flex;align-items:flex-start;gap:10px;">
                {{ link.logo }}
                <span style="flex:1;min-width:0;font-family:var(--font-display);font-weight:700;font-size:15.5px;color:var(--text-strong);line-height:1.45;">{{ link.title }}</span>
                <span role="button" tabindex="0" onClick="{{ link.toggleFav }}" title="お気に入りに保存" style="flex:none;cursor:pointer;font-size:19px;line-height:1;color:{{ link.starColor }};">{{ link.starChar }}</span>
              </div>
              <p style="flex:1;margin:0;font-size:13px;color:var(--text-muted);line-height:1.7;">{{ link.desc }}</p>
              <div style="display:flex;align-items:center;gap:6px;font-size:11.5px;color:var(--text-faint);font-family:var(--font-mono);overflow:hidden;">
                <span style="color:var(--brand);flex:none;">↗</span><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ link.host }}</span>
              </div>
            </a>
          </sc-for>
        </div>

        <div style="margin-top:26px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
          <h3 style="font-family:var(--font-display);font-weight:700;font-size:17px;color:var(--text-strong);margin:0;">分野別データ集</h3>
          <div style="display:inline-flex;background:var(--surface-2);border:1px solid var(--border);border-radius:999px;padding:3px;gap:2px;">
            <button onClick="{{ setTabsView }}" style="{{ tabsBtnStyle }}">タブ表示</button>
            <button onClick="{{ setAccordionView }}" style="{{ accBtnStyle }}">アコーディオン表示</button>
          </div>
        </div>

        <sc-if value="{{ isTabs }}" hint-placeholder-val="{{ true }}">
          <div style="margin-top:14px;">
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:15px;">
              <sc-for list="{{ tabs }}" as="tab" hint-placeholder-count="4">
                <button onClick="{{ tab.onClick }}" style="{{ tab.style }}">{{ tab.label }}</button>
              </sc-for>
            </div>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(258px,1fr));gap:14px;">
              <sc-for list="{{ activeGroupLinks }}" as="link" hint-placeholder-count="3">
                <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer" style="position:relative;display:flex;flex-direction:column;gap:9px;text-decoration:none;background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:17px 17px 15px;box-shadow:var(--shadow-sm);transition:transform .22s cubic-bezier(.34,1.56,.64,1),box-shadow .22s ease,border-color .22s ease;" style-hover="transform:translateY(-4px);box-shadow:var(--shadow-lg);border-color:var(--brand);">
                  <div style="display:flex;align-items:flex-start;gap:10px;">
                    {{ link.logo }}
                <span style="flex:1;min-width:0;font-family:var(--font-display);font-weight:700;font-size:15.5px;color:var(--text-strong);line-height:1.45;">{{ link.title }}</span>
                    <span role="button" tabindex="0" onClick="{{ link.toggleFav }}" title="お気に入りに保存" style="flex:none;cursor:pointer;font-size:19px;line-height:1;color:{{ link.starColor }};">{{ link.starChar }}</span>
                  </div>
                  <p style="flex:1;margin:0;font-size:13px;color:var(--text-muted);line-height:1.7;">{{ link.desc }}</p>
                  <div style="display:flex;align-items:center;gap:6px;font-size:11.5px;color:var(--text-faint);font-family:var(--font-mono);overflow:hidden;">
                    <span style="color:var(--brand);flex:none;">↗</span><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ link.host }}</span>
                  </div>
                </a>
              </sc-for>
            </div>
            <sc-if value="{{ activeGroupEmpty }}" hint-placeholder-val="{{ false }}">
              <p style="font-size:13.5px;color:var(--text-muted);padding:8px 2px;">この分野に該当する資料はありません。</p>
            </sc-if>
          </div>
        </sc-if>

        <sc-if value="{{ isAccordion }}" hint-placeholder-val="{{ false }}">
          <div style="margin-top:14px;display:flex;flex-direction:column;gap:10px;">
            <sc-for list="{{ accGroups }}" as="group" hint-placeholder-count="4">
              <div style="background:var(--surface);border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:var(--shadow-sm);">
                <button onClick="{{ group.onClick }}" style="width:100%;box-sizing:border-box;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:15px 18px;background:none;border:none;cursor:pointer;font-family:var(--font-display);font-weight:700;font-size:16px;color:var(--text-strong);text-align:left;">
                  <span style="display:flex;align-items:center;gap:11px;">
                    <span style="flex:none;min-width:22px;height:22px;padding:0 7px;border-radius:999px;background:var(--brand-soft);color:var(--brand-strong);display:inline-flex;align-items:center;justify-content:center;font-size:12px;">{{ group.count }}</span>
                    {{ group.label }}
                  </span>
                  <span style="{{ group.iconStyle }}">⌄</span>
                </button>
                <sc-if value="{{ group.isOpen }}" hint-placeholder-val="{{ true }}">
                  <div style="padding:0 18px 18px;display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px;">
                    <sc-for list="{{ group.links }}" as="link" hint-placeholder-count="2">
                      <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer" style="position:relative;display:flex;flex-direction:column;gap:8px;text-decoration:none;background:var(--surface-2);border:1px solid var(--border);border-radius:14px;padding:14px 14px 12px;transition:transform .2s cubic-bezier(.34,1.56,.64,1),border-color .2s ease;" style-hover="transform:translateY(-3px);border-color:var(--brand);">
                        <div style="display:flex;align-items:flex-start;gap:8px;">
                          {{ link.logoSm }}
                          <span style="flex:1;min-width:0;font-family:var(--font-display);font-weight:700;font-size:14.5px;color:var(--text-strong);line-height:1.45;">{{ link.title }}</span>
                          <span role="button" tabindex="0" onClick="{{ link.toggleFav }}" title="お気に入りに保存" style="flex:none;cursor:pointer;font-size:17px;line-height:1;color:{{ link.starColor }};">{{ link.starChar }}</span>
                        </div>
                        <p style="margin:0;font-size:12.5px;color:var(--text-muted);line-height:1.65;">{{ link.desc }}</p>
                        <div style="display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text-faint);font-family:var(--font-mono);overflow:hidden;">
                          <span style="color:var(--brand);flex:none;">↗</span><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ link.host }}</span>
                        </div>
                      </a>
                    </sc-for>
                  </div>
                </sc-if>
              </div>
            </sc-for>
          </div>
        </sc-if>
      </section>
    </sc-if>

    <sc-for list="{{ sectionsBottom }}" as="section" hint-placeholder-count="2">
      <section id="{{ section.key }}" style="scroll-margin-top:160px;margin-top:50px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:4px;">
          <span style="width:11px;height:24px;border-radius:6px;background:{{ section.accent }};flex:none;"></span>
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:25px;color:var(--text-strong);margin:0;letter-spacing:-.01em;">{{ section.label }}</h2>
          <span style="font-family:var(--font-display);font-weight:700;font-size:12px;padding:3px 10px;border-radius:999px;background:{{ section.accentSoft }};color:{{ section.accent }};">{{ section.count }}</span>
        </div>
        <p style="margin:0 0 18px 23px;font-size:13.5px;color:var(--text-muted);">{{ section.desc }}</p>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(262px,1fr));gap:14px;">
          <sc-for list="{{ section.links }}" as="link" hint-placeholder-count="2">
            <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer" style="position:relative;display:flex;flex-direction:column;gap:9px;text-decoration:none;background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:17px 17px 15px;box-shadow:var(--shadow-sm);transition:transform .22s cubic-bezier(.34,1.56,.64,1),box-shadow .22s ease,border-color .22s ease;" style-hover="transform:translateY(-4px);box-shadow:var(--shadow-lg);border-color:var(--brand);">
              <div style="display:flex;align-items:flex-start;gap:10px;">
                {{ link.logo }}
                <span style="flex:1;min-width:0;font-family:var(--font-display);font-weight:700;font-size:15.5px;color:var(--text-strong);line-height:1.45;">{{ link.title }}</span>
                <span role="button" tabindex="0" onClick="{{ link.toggleFav }}" title="お気に入りに保存" style="flex:none;cursor:pointer;font-size:19px;line-height:1;color:{{ link.starColor }};">{{ link.starChar }}</span>
              </div>
              <p style="flex:1;margin:0;font-size:13px;color:var(--text-muted);line-height:1.7;">{{ link.desc }}</p>
              <div style="display:flex;align-items:center;gap:6px;font-size:11.5px;color:var(--text-faint);font-family:var(--font-mono);overflow:hidden;">
                <span style="color:var(--brand);flex:none;">↗</span><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ link.host }}</span>
              </div>
            </a>
          </sc-for>
        </div>
      </section>
    </sc-for>

  </main>

  <footer style="border-top:1px solid var(--border);margin-top:60px;padding:36px 24px;background:var(--surface-2);">
    <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:18px;flex-wrap:wrap;">
      <img src="data:image/png;base64," alt="ふたば" width="58" style="animation:floaty 4.5s ease-in-out infinite;flex:none;" />
      <div style="flex:1;min-width:200px;">
        <p style="margin:0;font-family:var(--font-display);font-weight:700;font-size:17px;color:var(--text-strong);">まず、一次情報にあたろう。</p>
        <p style="margin:4px 0 0;font-size:12.5px;color:var(--text-muted);">総合的な探究の時間 — リサーチポータル。リンクは新しいタブで開きます。★でお気に入りを保存できます。</p>
      </div>
    </div>
  </footer>

</div>
</x-dc>
<script type="text/x-dc" data-dc-script data-props="{&quot;$preview&quot;:{&quot;width&quot;:1200,&quot;height&quot;:900}}">
class Component extends DCLogic {
  constructor(props){
    super(props);
    this.state = { query:'', activeCat:'all', showFav:false, favorites:[], theme:'light', statsView:'tabs', activeTab:'env', openGroups:{env:true,region:false,humanities:false,science:false}, copied:'', eventView:'carousel', evtIndex:0, evtData:null, evtThumbs:{} };
    this.trackRef = React.createRef();
    this._evtPaused = false;

    this.DATA = {
      cats:[
        {key:'all',label:'すべて'},{key:'general',label:'総探全般'},{key:'research',label:'先行研究'},
        {key:'books',label:'図書'},{key:'news',label:'新聞記事'},{key:'stats',label:'統計データ'},
        {key:'themes',label:'テーマ例'},{key:'design',label:'デザイン'}
      ],
      generic:[
        {key:'general',label:'総探全般',accent:'#189048',accentSoft:'#e8f6ee',desc:'探究の進め方や全体像をつかむための入口。',links:[
          {title:'「総合的な学習（探究）の時間」応援団のページ',url:'https://www.mext.go.jp/a_menu/shotou/sougou/syokatsu.htm',desc:'文部科学省。膨大な資料があるため、検索ワードの活用がおすすめ。'},
          {title:'総合的な探究の時間 | NHK高校講座',url:'https://www.nhk.or.jp/kokokoza/tanq/',desc:'映像で探究の基本を学べるNHKの高校講座。'},
          {title:'探究学習「情報の収集／整理・分析」リンク集【無料】',url:'https://www.blog.studyvalley.jp/2021/08/26/link/',desc:'Far East Tokyo。情報収集・整理分析に使えるリンクのまとめ。'}
        ]},
        {key:'research',label:'先行研究',accent:'#2e9bd6',accentSoft:'#def0fb',desc:'論文検索サイト。一次情報・学術情報はここから。',links:[
          {title:'CiNii Research',url:'https://cir.nii.ac.jp/',desc:'日本最大級の論文・研究データの横断検索。'},
          {title:'J-STAGE',url:'https://www.jstage.jst.go.jp/browse/-char/ja/',desc:'国内の学術論文・学会誌を検索・閲覧できる。'},
          {title:'Google Scholar',url:'https://scholar.google.co.jp/schhp?hl=ja',desc:'多言語対応。海外の論文検索に。'},
          {title:'国立国会図書館サーチ（NDLサーチ）',url:'https://ndlopac.ndl.go.jp/',desc:'全国の図書館や研究機関の資料を統合検索できる。'},
          {title:'リサーチ・ナビ | 国立国会図書館',url:'https://rnavi.ndl.go.jp/rnavi/',desc:'「調べ方案内」の紹介。ウェブサイトのリンク集も便利。'},
          {title:'国立国会図書館デジタルコレクション',url:'http://dl.ndl.go.jp/',desc:'電子書籍・雑誌を検索・閲覧できる。'},
          {title:'IRDB 学術機関リポジトリデータベース',url:'https://irdb.nii.ac.jp/',desc:'全国の大学リポジトリ（紀要・論文）を横断検索。'}
        ]},
        {key:'books',label:'図書',accent:'#b98900',accentSoft:'#fff3cc',desc:'本を探す・所蔵を調べる・古書を当たる。',links:[
          {title:'カーリル',url:'https://calil.jp/',desc:'全国の図書館の貸出状況をリアルタイムで簡単に検索。'},
          {title:'Webcat Plus',url:'http://webcatplus.nii.ac.jp/',desc:'日本で出版された本の検索や、連想検索ができる。'},
          {title:'想・IMAGINE',url:'http://imagine.bookmap.info/index.jsp',desc:'単語や文章から各データベースを連想検索。'},
          {title:'日本の古本屋',url:'https://www.kosho.or.jp/',desc:'古本・古書の検索・通販サイト。'},
          {title:'Google ブックス',url:'https://books.google.co.jp/',desc:'本文の一部を検索・試し読みできる。'},
          {title:'青空文庫',url:'https://www.aozora.gr.jp/',desc:'著作権切れ作品が読める電子図書館。'}
        ]},
        {key:'themes',label:'テーマ例',accent:'#db5e45',accentSoft:'#fde8e2',desc:'高校生の探究テーマの実例から発想を得る。',links:[
          {title:'みんなの探究ライブラリ',url:'https://www.benesse.co.jp/tankyu/event/library/index.html',desc:'Benesse。探究テーマの実例集。'},
          {title:'高等部1年生 発表テーマ一覧（PDF）',url:'https://www.junten.ed.jp/contents/wp-content/uploads/2022/03/b700dbb307a29fd6e8106d7ced03493d.pdf',desc:'実際の発表テーマ一覧。発想のヒントに。'}
        ]},
        {key:'design',label:'デザイン作成',accent:'#1e7db4',accentSoft:'#def0fb',desc:'発表資料を「伝わる」形に整える。',links:[
          {title:'伝わるデザイン',url:'https://student.tsutawarudesign.com/',desc:'発表スライド・資料づくりの基本が学べる。'},
          {title:'いらすとや',url:'https://www.irasutoya.com/',desc:'発表資料に使えるフリーイラスト素材。'},
          {title:'Adobe Color',url:'https://color.adobe.com/ja/create',desc:'配色（カラーパレット）を作れるツール。'}
        ]}
      ],
      asahi:{title:'朝日けんさくくん',url:'https://kensaku.asahi.com/',id:'dks669ken',pw:'34a82vbsmy',desc:'朝日新聞の過去記事を検索できるデータベース。'},
      statsTop:[
        {title:'e-Stat 政府統計の総合窓口',url:'https://www.e-stat.go.jp/',desc:'日本の政府統計データの総合窓口。'},
        {title:'RESAS 地域経済分析システム',url:'https://resas.go.jp/#/13/13101',desc:'地域経済を可視化して分析できるシステム。'},
        {title:'統計ダッシュボード',url:'https://dashboard.e-stat.go.jp/',desc:'主要な統計をグラフで見られる。e-Statの可視化版。'}
      ],
      statsGroups:[
        {key:'env',label:'① 環境問題系',links:[
          {title:'SDGs17の目標別動画クリップ | NHK for School',url:'https://www.nhk.or.jp/school/17goals/',desc:'目標別の短い動画クリップ。'},
          {title:'SDGsを学べる教材 | JICA',url:'https://www.jica.go.jp/cooperation/learn/material/sdgs.html',desc:'JICAのSDGs学習教材。'},
          {title:'NHK地域づくりアーカイブス',url:'https://www.nhk.or.jp/chiiki/',desc:'地域の取り組み。SDGs関連もあり。'},
          {title:'気象庁 過去の気象データ検索',url:'https://www.data.jma.go.jp/obd/stats/etrn/',desc:'気温・降水量などの実測データを取得できる。'}
        ]},
        {key:'region',label:'② 地域系',links:[
          {title:'NHK地域づくりアーカイブス',url:'https://www.nhk.or.jp/chiiki/',desc:'全国の地域づくりの事例アーカイブ。'},
          {title:'jSTAT MAP（地図で見る統計）',url:'https://jstatmap.e-stat.go.jp/',desc:'統計データを地図上で可視化できる。'}
        ]},
        {key:'humanities',label:'③ 文系',links:[
          {title:'NHKラーニング',url:'https://www.nhk.or.jp/learning/',desc:'幅広い分野の学習コンテンツ。'},
          {title:'現代日本語書き言葉均衡コーパス（BCCWJ）',url:'https://clrd.ninjal.ac.jp/bccwj/',desc:'少納言（登録不要）・中納言（登録必要）で日本語の使われ方を検索。'},
          {title:'怪異・妖怪伝承データベース | 日文研',url:'https://www.nichibun.ac.jp/YoukaiDB/',desc:'国際日本文化研究センターのデータベース。'},
          {title:'雑誌『国語学』全文データベース',url:'https://bibdb.ninjal.ac.jp/SJL/',desc:'国語学系の論文検索DB。'},
          {title:'e-Gov',url:'https://www.e-gov.go.jp/',desc:'政府文書や言葉・国際機関での定義を確認できる。'}
        ]},
        {key:'science',label:'④ 理系',links:[
          {title:'理科自由研究データベース',url:'http://sec-db.cf.ocha.ac.jp/',desc:'お茶の水女子大。自由研究の事例DB。'},
          {title:'日本学生科学賞',url:'https://event.yomiuri.co.jp/jssa/',desc:'読売新聞主催の科学コンクール。'},
          {title:'JSEC（高校生・高専生科学技術チャレンジ）',url:'https://manabu.asahi.com/jsec/',desc:'朝日新聞主催の科学技術コンテスト。'}
        ]}
      ],
      seminarsFallback:[
        {id:'s1',title:'高校生探究フォーラム2026 ～問いから始まる学び～',date:'2026-07-26',deadline:'2026-07-18',organizer:'全国高校探究教育ネットワーク',target:'高校1〜3年',format:'online',applyUrl:'https://example.org/tankyu-forum-2026',pdf:'seminars/sample-tankyu-forum.pdf',accent:'#189048'},
        {id:'s2',title:'SDGs課題研究ワークショップ（夏期集中）',date:'2026-08-03',deadline:'2026-07-25',organizer:'地域未来研究センター',target:'高校2〜3年',format:'onsite',applyUrl:'https://example.org/sdgs-workshop',pdf:'seminars/sample-sdgs-workshop.pdf',accent:'#ee7e66'},
        {id:'s3',title:'データサイエンス入門セミナー｜統計で社会を読む',date:'2026-08-20',deadline:'2026-08-10',organizer:'大学連携データサイエンス教育機構',target:'高校全学年',format:'hybrid',applyUrl:'https://example.org/ds-seminar',pdf:'seminars/sample-datascience.pdf',accent:'#4fb8e8'},
        {id:'s4',title:'地域フィールドワーク成果発表会',date:'2026-09-07',deadline:'2026-08-28',organizer:'ふるさと探究プロジェクト実行委員会',target:'高校1〜3年',format:'onsite',applyUrl:'https://example.org/fieldwork-presentation',pdf:'seminars/sample-fieldwork.pdf',accent:'#f7b500'},
        {id:'s5',title:'論文の書き方・引用のルール 基礎講座',date:'2026-09-21',deadline:'2026-09-12',organizer:'学術リテラシー支援室',target:'高校2〜3年',format:'online',applyUrl:'https://example.org/academic-writing',pdf:'seminars/sample-writing.pdf',accent:'#2e9bd6'}
      ]
    };
  }

  componentDidMount(){
    try{
      const f = JSON.parse(localStorage.getItem('tankyu-favorites')||'[]');
      const t = localStorage.getItem('tankyu-theme')||'light';
      this.setState({ favorites: Array.isArray(f)?f:[], theme: (t==='dark'?'dark':'light') });
    }catch(e){}
    this.loadSeminars();
    this._evtTimer = setInterval(()=>{ if(!this._evtPaused && this.state.eventView==='carousel') this.advanceEvt(1, true); }, 4200);
  }

  componentWillUnmount(){ clearInterval(this._evtTimer); clearTimeout(this._clickT); clearTimeout(this._ct); }

  loadSeminars(){
    const fallback = (this.DATA && this.DATA.seminarsFallback) || [];
    fetch('seminars/seminars.json').then(r=> r.ok ? r.json() : Promise.reject()).then(d=>{
      const arr = Array.isArray(d) && d.length ? d : fallback;
      this.setState({ evtData: arr });
      this.renderThumbs(arr);
    }).catch(()=>{
      this.setState({ evtData: fallback });
      this.renderThumbs(fallback);
    });
  }

  renderThumbs(arr){
    const lib = window.pdfjsLib;
    if(!lib || !arr) return;
    try{ lib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js'; }catch(e){}
    arr.forEach(ev=>{
      if(!ev.pdf) return;
      lib.getDocument(ev.pdf).promise.then(pdf=> pdf.getPage(1)).then(page=>{
        const vp0 = page.getViewport({scale:1});
        const scale = Math.min(2, 520/vp0.width);
        const vp = page.getViewport({scale});
        const canvas = document.createElement('canvas');
        canvas.width = vp.width; canvas.height = vp.height;
        return page.render({canvasContext:canvas.getContext('2d'), viewport:vp}).promise.then(()=> canvas.toDataURL('image/png'));
      }).then(url=>{
        this.setState(s=>({ evtThumbs: Object.assign({}, s.evtThumbs, {[ev.id]: url}) }));
      }).catch(()=>{});
    });
  }

  stride(){
    const tr = this.trackRef.current;
    if(!tr || !tr.children.length) return 271;
    const first = tr.children[0];
    return first.offsetWidth + 16;
  }
  advanceEvt(dir, wrap){
    const arr = this.state.evtData || [];
    if(!arr.length) return;
    const tr = this.trackRef.current;
    let i = this.state.evtIndex + dir;
    if(i >= arr.length) i = wrap ? 0 : arr.length-1;
    if(i < 0) i = 0;
    if(tr) tr.scrollTo({ left: i*this.stride(), behavior:'smooth' });
    this.setState({ evtIndex: i });
  }
  goEvt(i){
    const tr = this.trackRef.current;
    if(tr) tr.scrollTo({ left: i*this.stride(), behavior:'smooth' });
    this.setState({ evtIndex: i });
  }

  matches(l){
    const q = this.state.query.trim().toLowerCase();
    if(this.state.showFav && !this.state.favorites.includes(l.url)) return false;
    if(!q) return true;
    return ((l.title||'')+' '+(l.desc||'')+' '+(l.url||'')).toLowerCase().includes(q);
  }

  decorate(l, accent, accentSoft){
    let host = l.url;
    try{ host = new URL(l.url).hostname.replace(/^www\./,''); }catch(e){}
    const isFav = this.state.favorites.includes(l.url);
    const self = this;
    const soft = accentSoft||'var(--surface-2)';
    const favicon = 'https://www.google.com/s2/favicons?domain='+host+'&sz=64';
    const initial = (host.charAt(0)||'?').toUpperCase();
    const makeLogo = (size,radius,pad,font)=> React.createElement('span',{style:{position:'relative',flex:'none',width:size,height:size,borderRadius:radius,background:soft,border:'1px solid var(--border)',display:'flex',alignItems:'center',justifyContent:'center',overflow:'hidden',fontFamily:'var(--font-display)',fontWeight:700,fontSize:font,color:accent}},
      initial,
      React.createElement('img',{src:favicon,alt:'',loading:'lazy',onError:function(e){ if(e&&e.target){ e.target.style.display='none'; } },style:{position:'absolute',inset:0,width:'100%',height:'100%',objectFit:'contain',padding:pad,boxSizing:'border-box',background:soft}}));
    return Object.assign({}, l, {
      host, accent, accentSoft: soft, isFav,
      logo: makeLogo('36px','10px','7px','15px'),
      logoSm: makeLogo('30px','8px','6px','13px'),
      starChar: isFav ? '★' : '☆',
      starColor: isFav ? 'var(--gold)' : 'var(--text-faint)',
      toggleFav: function(e){ if(e&&e.preventDefault){e.preventDefault();e.stopPropagation();} self.toggleFav(l.url); }
    });
  }

  toggleFav(url){
    this.setState(s=>{
      const has = s.favorites.includes(url);
      const favorites = has ? s.favorites.filter(u=>u!==url) : s.favorites.concat([url]);
      try{ localStorage.setItem('tankyu-favorites', JSON.stringify(favorites)); }catch(e){}
      return { favorites };
    });
  }

  setCat(k){ const self=this; return function(){ self.setState({activeCat:k}); }; }
  setTab(k){ const self=this; return function(){ self.setState({activeTab:k}); }; }
  toggleGroup(k){ const self=this; return function(){ self.setState(s=>({openGroups:Object.assign({},s.openGroups,{[k]:!s.openGroups[k]})})); }; }
  copy(field,text){ const self=this; return function(){ try{navigator.clipboard.writeText(text);}catch(e){} self.setState({copied:field}); clearTimeout(self._ct); self._ct=setTimeout(()=>self.setState({copied:''}),1600); }; }

  darken(hex,f){ try{ let h=String(hex).replace('#',''); if(h.length===3) h=h.split('').map(c=>c+c).join(''); const r=Math.round(parseInt(h.slice(0,2),16)*f), g=Math.round(parseInt(h.slice(2,4),16)*f), b=Math.round(parseInt(h.slice(4,6),16)*f); return 'rgb('+r+','+g+','+b+')'; }catch(e){ return '#1b3a26'; } }

  renderVals(){
    const st = this.state;
    const cat = st.activeCat;
    const filterActive = st.query.trim()!=='' || st.showFav;

    // ----- Seminars / Events -----
    const fmtDate = (s)=>{ if(!s) return '未定'; const p=String(s).split('-'); if(p.length<3) return s; const wd=['日','月','火','水','木','金','土'][new Date(+p[0],+p[1]-1,+p[2]).getDay()]; return (+p[1])+'/'+(+p[2])+'（'+wd+'）'; };
    const fmtShort = (s)=>{ if(!s) return '未定'; const p=String(s).split('-'); if(p.length<3) return s; return (+p[1])+'/'+(+p[2]); };
    const daysTo = (s)=>{ if(!s) return null; const p=String(s).split('-'); if(p.length<3) return null; const d=new Date(+p[0],+p[1]-1,+p[2]); const now=new Date(); now.setHours(0,0,0,0); return Math.round((d-now)/86400000); };
    const fmtMap = { online:{label:'オンライン',c:'#4fb8e8'}, onsite:{label:'対面',c:'#ee7e66'}, hybrid:{label:'ハイブリッド',c:'#e0a800'} };
    const badgeStr = (c)=> 'display:inline-flex;align-items:center;padding:4px 10px;border-radius:999px;font-family:var(--font-display);font-weight:700;font-size:10.5px;background:'+c+';color:#fff;box-shadow:0 1px 4px rgba(0,0,0,.2);';
    const self2 = this;
    const openClick = (ev)=> function(){ clearTimeout(self2._clickT); const href = ev.pdf || ev.applyUrl; self2._clickT = setTimeout(()=>{ if(href) window.open(href,'_blank','noopener'); }, 230); };
    const openDbl = (ev)=> function(){ clearTimeout(self2._clickT); if(ev.applyUrl) window.open(ev.applyUrl,'_blank','noopener'); };
    const evtRaw = st.evtData || [];
    const events = evtRaw.map(ev=>{
      const accent = ev.accent || '#189048';
      const fm = fmtMap[ev.format] || {label:ev.format||'—',c:'#6e7363'};
      const thumb = st.evtThumbs[ev.id] || '';
      const dd = daysTo(ev.deadline);
      const isSoon = dd!==null && dd>=0 && dd<=7;
      return {
        id:ev.id, title:ev.title||'（無題）', accent,
        dateLabel:fmtDate(ev.date), deadlineLabel:fmtShort(ev.deadline),
        organizer:ev.organizer||'—', target:ev.target||'—',
        formatLabel:fm.label, formatBadge:badgeStr(fm.c),
        thumb, hasThumb:!!thumb, noThumb:!thumb, posterBg:this.darken(accent,0.5),
        thumbImg: thumb ? React.createElement('img',{src:thumb,alt:'',style:{position:'absolute',inset:0,width:'100%',height:'100%',objectFit:'cover',objectPosition:'top center'}}) : null,
        isSoon, soonLabel: dd===0?'本日締切':('締切まであと'+dd+'日'),
        applyUrl:ev.applyUrl||'#', pdfHref:ev.pdf||ev.applyUrl||'#',
        onClick:openClick(ev), onDblClick:openDbl(ev)
      };
    });
    const evtDots = events.map((e,i)=>({
      onClick:(()=>{ const idx=i; return ()=>this.goEvt(idx); })(),
      style:{cursor:'pointer',border:'none',padding:0,height:'8px',borderRadius:'999px',transition:'all .2s',width: i===st.evtIndex?'22px':'8px',background: i===st.evtIndex?'var(--brand)':'var(--border-strong)'}
    }));

    const buildGeneric = (arr)=> arr.map(sec=>{
      const links = sec.links.filter(l=>this.matches(l)).map(l=>this.decorate(l, sec.accent, sec.accentSoft));
      const visible = (cat==='all'||cat===sec.key) && links.length>0;
      return { key:sec.key, label:sec.label, desc:sec.desc, accent:sec.accent, accentSoft:sec.accentSoft, links, count:links.length, _v:visible };
    }).filter(s=>s._v);

    const sectionsTop = buildGeneric(this.DATA.generic.slice(0,3));
    const sectionsBottom = buildGeneric(this.DATA.generic.slice(3));

    // News
    const a = this.DATA.asahi;
    const asahiMatch = this.matches({title:a.title,desc:a.desc,url:a.url});
    const newsVisible = (cat==='all'||cat==='news') && asahiMatch;
    const asahiDec = this.decorate(a, '#db5e45', '#fde8e2');

    // Stats
    const statsTop = this.DATA.statsTop.filter(l=>this.matches(l)).map(l=>this.decorate(l,'#6f8a12','#eef3cf'));
    const groups = this.DATA.statsGroups.map(g=>{
      const links = g.links.filter(l=>this.matches(l)).map(l=>this.decorate(l,'#6f8a12','#eef3cf'));
      return { key:g.key, label:g.label, links, count:links.length };
    });
    const statsHasContent = statsTop.length>0 || groups.some(g=>g.count>0);
    const statsVisible = (cat==='all'||cat==='stats') && statsHasContent;

    const chipStyle = (active)=>({cursor:'pointer',whiteSpace:'nowrap',fontFamily:'var(--font-display)',fontWeight:700,fontSize:'13px',padding:'7px 14px',borderRadius:'999px',transition:'all .18s',border:'1px solid '+(active?'transparent':'var(--border)'),background:active?'var(--brand)':'var(--surface)',color:active?'#fff':'var(--text-body)'});
    const chips = this.DATA.cats.map(c=>({key:c.key,label:c.label,onClick:this.setCat(c.key),style:chipStyle(cat===c.key)}));

    const tabs = this.DATA.statsGroups.map(g=>({key:g.key,label:g.label,onClick:this.setTab(g.key),style:chipStyle(st.activeTab===g.key)}));
    const activeG = groups.find(g=>g.key===st.activeTab) || groups[0];
    const activeGroupLinks = activeG ? activeG.links : [];

    const accGroups = groups.map(g=>({
      key:g.key,label:g.label,links:g.links,count:g.count,
      isOpen: !!st.openGroups[g.key],
      onClick: this.toggleGroup(g.key),
      iconStyle: {display:'inline-block',transition:'transform .2s ease',transform: st.openGroups[g.key]?'rotate(180deg)':'rotate(0deg)',color:'var(--text-muted)',fontSize:'17px'}
    })).filter(g=> filterActive ? g.count>0 : true);

    const segStyle = (active)=>({cursor:'pointer',border:'none',fontFamily:'var(--font-display)',fontWeight:700,fontSize:'13px',padding:'7px 15px',borderRadius:'999px',transition:'all .18s',background:active?'var(--brand)':'transparent',color:active?'#fff':'var(--text-muted)'});

    const copyBtn = (copied)=>({cursor:'pointer',border:'none',fontFamily:'var(--font-display)',fontWeight:700,fontSize:'12px',padding:'7px 13px',borderRadius:'8px',transition:'all .18s',whiteSpace:'nowrap',background:copied?'var(--brand)':'var(--brand-soft)',color:copied?'#fff':'var(--brand-strong)'});

    const resultCount = sectionsTop.concat(sectionsBottom).reduce((n,s)=>n+s.count,0)
      + (newsVisible?1:0) + statsTop.length + groups.reduce((n,g)=>n+g.count,0);

    const noResults = sectionsTop.length===0 && sectionsBottom.length===0 && !newsVisible && !statsVisible;

    return {
      theme: st.theme,
      themeIsDark: st.theme==='dark',
      themeIsLight: st.theme!=='dark',
      toggleTheme: ()=>this.setState(s=>{ const theme=s.theme==='dark'?'light':'dark'; try{localStorage.setItem('tankyu-theme',theme);}catch(e){} return {theme}; }),

      events, evtCount: events.length, evtDots,
      isCarousel: st.eventView==='carousel',
      isList: st.eventView==='list',
      setCarouselView: ()=>this.setState({eventView:'carousel'}),
      setListView: ()=>this.setState({eventView:'list'}),
      carBtnStyle: segStyle(st.eventView==='carousel'),
      listBtnStyle: segStyle(st.eventView==='list'),
      trackRef: this.trackRef,
      evtPrev: ()=>this.advanceEvt(-1,false),
      evtNext: ()=>this.advanceEvt(1,false),
      evtPause: ()=>{ this._evtPaused=true; },
      evtResume: ()=>{ this._evtPaused=false; },

      query: st.query,
      setQuery: (e)=>this.setState({query:e.target.value}),

      chips,
      favCount: st.favorites.length,
      toggleFavView: ()=>this.setState(s=>({showFav:!s.showFav})),
      favBtnStyle: {flex:'none',display:'inline-flex',alignItems:'center',gap:'6px',cursor:'pointer',fontFamily:'var(--font-display)',fontWeight:700,fontSize:'13px',padding:'8px 13px',borderRadius:'999px',transition:'all .2s',border:'1px solid '+(st.showFav?'transparent':'var(--border)'),background:st.showFav?'var(--gold)':'var(--surface)',color:st.showFav?'#4a3500':'var(--text-body)'},

      filterActive, resultCount, noResults,

      sectionsTop, sectionsBottom,

      newsVisible,
      asahiStarChar: asahiDec.starChar,
      asahiStarColor: asahiDec.starColor,
      asahiToggleFav: asahiDec.toggleFav,
      copyId: this.copy('id', a.id),
      copyPw: this.copy('pw', a.pw),
      copyIdLabel: st.copied==='id'?'コピー済み':'コピー',
      copyPwLabel: st.copied==='pw'?'コピー済み':'コピー',
      copyIdStyle: copyBtn(st.copied==='id'),
      copyPwStyle: copyBtn(st.copied==='pw'),

      statsVisible, statsTop,
      isTabs: st.statsView==='tabs',
      isAccordion: st.statsView==='accordion',
      setTabsView: ()=>this.setState({statsView:'tabs'}),
      setAccordionView: ()=>this.setState({statsView:'accordion'}),
      tabsBtnStyle: segStyle(st.statsView==='tabs'),
      accBtnStyle: segStyle(st.statsView==='accordion'),
      tabs, activeGroupLinks, accGroups,
      activeGroupEmpty: activeGroupLinks.length===0
    };
  }
}
</script>
</body>
</html>
